# Anvil — Environment Configuration
# Copy to .env and adjust paths for your setup.

# Required: path to your application materials (each company = a subdirectory)
APPLICATIONS_DIR=/data/applications

# Required: where to store the SQLite database
DB_PATH=/data/db/review_notes.db

# Required: auto-backup directory for all edits
BACKUP_DIR=/data/backups

# Optional: path to a directory of .md research/evidence files
# These appear in the evidence sidebar (Ctrl+E) for reference while writing.
EVIDENCE_DIR=/data/evidence

# Optional: path to fellowship application materials for resume import
FELLOWSHIP_DIR=/data/fellowship

# Optional: headless Chromium path for resume PDF generation
CHROMIUM_PATH=/usr/bin/chromium

# Optional: SMTP config for "email to self" export feature
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# EMAIL_TO=you@example.com
